  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.250",
    "@remotion/cli": "4.0.250",
    "@remotion/google-fonts": "4.0.250"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/node": "22.10.0",
    "typescript": "5.6.3"
  }
}
