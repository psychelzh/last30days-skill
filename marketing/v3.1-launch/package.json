{
  "name": "last30days-v3-1-launch-video",
  "version": "0.1.0",
  "private": true,
  "description": "30s Remotion launch video for /last30days v3.1 (competitors mode).",
  "scripts": {
    "preview": "remotion studio src/index.ts",
